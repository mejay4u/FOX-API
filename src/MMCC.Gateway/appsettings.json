{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {

      "idcard-route": {
        "ClusterId": "idcard-cluster",
        "Match": { "Path": "/idcard/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/idcard" }
        ]
      },

      "bff-route": {
        "ClusterId": "bff-cluster",
        "Match": { "Path": "/bff/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/bff" }
        ]
      },

      "claims-route": {
        "ClusterId": "claims-cluster",
        "Match": { "Path": "/claims/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/claims" }
        ]
      },

      "member-route": {
        "ClusterId": "member-cluster",
        "Match": { "Path": "/member/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/member" }
        ]
      },

      "mobile-route": {
        "ClusterId": "mobile-cluster",
        "Match": { "Path": "/mobile/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/mobile" }
        ]
      }
    },

    "Clusters": {

      "idcard-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5010/" }
        }
      },

      "bff-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5011/" }
        }
      },

      "claims-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5012/" }
        }
      },

      "member-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5013/" }
        }
      },

      "mobile-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5014/" }
        }
      }
    }
  }
}
