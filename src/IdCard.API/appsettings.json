{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdCard": {
    "BasePath": "IdCard"
  },
  "IbmMq": {
    "Enabled": false,
    "QueueManagerName": "QM_IDCARD",
    "ConnectionName": "mqhost.example.com",
    "Channel": "IDCARD.CHANNEL",
    "Port": 1414,
    "RequestQueueName": "IDCARD.REQUEST.Q",
    "ReplyQueueName": "IDCARD.REPLY.Q",
    "Environment": "PROD",
    "TimeoutMs": 30000
  }
}
